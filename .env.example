# Database (dev/test — ignorado em produção, que usa DATABASE_URL)
DB_USERNAME=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5433

# Rails
RAILS_MAX_THREADS=5
SECRET_KEY_BASE=
JWT_SECRET=

# Frontend
FRONTEND_URL=http://localhost:5173

# Active Record encryption (ChannelCredential#credentials) — gerar com `bin/rails db:encryption:init`
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# ─── Produção (Easypanel) ────────────────────────────────────────────────
# Fornecidas pelos serviços gerenciados de Postgres/Redis do Easypanel.
DATABASE_URL=
REDIS_URL=

# config/master.key está no .dockerignore e portanto NÃO vai para a imagem —
# forneça RAILS_MASTER_KEY (conteúdo de config/master.key) como env var no
# Easypanel para decriptar config/credentials.yml.enc. Alternativa: setar
# SECRET_KEY_BASE diretamente (tem precedência e evita depender do master key).
RAILS_MASTER_KEY=

RAILS_LOG_TO_STDOUT=true
